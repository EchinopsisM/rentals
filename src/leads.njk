<div class="leads">
  {% for s in leads %}
  <article class="lead">
    <div class="lead-head">
      <h2><a href="{{ s.url }}" target="_blank" rel="noopener">{{ s.name }} ↗</a></h2>
      <span class="lead-kind">{{ s.kind }}</span>
    </div>
    <p class="lead-note">{{ s.note }}</p>
    <p class="lead-meta">Owner-direct: <strong>{{ s.likelihood }}</strong></p>
  </article>
  {% endfor %}
</div>
