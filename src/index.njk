---
layout: layout.njk
---
{% set sorted = listings | sort(true, false, "score") %}

<section class="hero">
  <h1>{{ site.title }}</h1>
  <p class="lede">{{ site.tagline }}</p>
  <p class="count"><strong id="visible-count">{{ listings | length }}</strong> listings · ranked by target score · <span id="fav-summary"></span>filter &amp; sort below · <a href="/map/">map →</a> · <a href="/buildings/">buildings to ask directly →</a> · <a href="/leads/">manual-check leads →</a></p>
</section>

<div class="filters" id="filters">
  <div class="fgroup">
    <span class="flabel">Zone</span>
    <button class="chip active" data-filter="zone" data-val="all">All</button>
    <button class="chip" data-filter="zone" data-val="target">Target</button>
    <button class="chip" data-filter="zone" data-val="target-edge">Suthep edge</button>
    <button class="chip" data-filter="zone" data-val="fallback">Fallback</button>
    <button class="chip" data-filter="zone" data-val="backup">Backup</button>
    <button class="chip" data-filter="zone" data-val="out">Out of zone</button>
  </div>
  <div class="fgroup">
    <span class="flabel">Max price</span>
    <button class="chip active" data-filter="price" data-val="99999">Any</button>
    <button class="chip" data-filter="price" data-val="13000">≤13k</button>
    <button class="chip" data-filter="price" data-val="16000">≤16k</button>
    <button class="chip" data-filter="price" data-val="20000">≤20k</button>
  </div>
  <div class="fgroup">
    <span class="flabel">Beds</span>
    <button class="chip active" data-filter="beds" data-val="0">Any</button>
    <button class="chip" data-filter="beds" data-val="2">2+</button>
    <button class="chip" data-filter="beds" data-val="3">3+</button>
  </div>
  <div class="fgroup">
    <span class="flabel">Marks</span>
    <button class="chip" id="toggle-taken" type="button">Show taken (<span id="taken-count">0</span>)</button>
    <button class="chip" id="clear-marks" type="button" hidden>Reset marks</button>
  </div>
  <div class="fgroup sortgroup">
    <span class="flabel">Sort by</span>
    <select id="sort" class="sortsel">
      <option value="score">Best target (score)</option>
      <option value="price">Price: low → high</option>
      <option value="price-desc">Price: high → low</option>
      <option value="recency">Most recently posted</option>
      <option value="movein">Earliest move-in</option>
      <option value="location">Closest location</option>
    </select>
  </div>
</div>

<details class="legend">
  <summary>How the target score works</summary>
  <p>Each listing is scored <strong>0–100</strong> from four weighted factors. Move-in date is weighted most strongly, per the brief.</p>
  <ul>
    <li><b>Move-in</b> <span>/40</span> — earliest move-in wins (“Ready now” = full marks).</li>
    <li><b>Location</b> <span>/25</span> — closeness to the CMU/Suthep target zone.</li>
    <li><b>Recency</b> <span>/20</span> — more recently posted = more likely still available.</li>
    <li><b>Price</b> <span>/15</span> — cheaper scores higher across the 10k–20k THB band.</li>
  </ul>
</details>

<div class="grid" id="grid">
  {% for l in sorted %}
  {% set zm = l.zone | zoneMeta %}
  {% set sc = l.score %}
  {% if sc >= 85 %}{% set scol = "#1f8a4c" %}{% elif sc >= 70 %}{% set scol = "#3f9d62" %}{% elif sc >= 60 %}{% set scol = "#c98a1a" %}{% else %}{% set scol = "#b14b4b" %}{% endif %}
  <article class="card"
    data-id="{{ l.id }}"
    data-zone="{{ l.zone }}"
    data-price="{{ l.priceNum }}"
    data-beds="{{ l.beds or 0 }}"
    data-score="{{ l.score }}"
    data-recency="{{ l.scoreBreakdown.recency.sub }}"
    data-movein="{{ l.scoreBreakdown.moveIn.sub }}"
    data-location="{{ l.scoreBreakdown.location.sub }}">
    <a class="card-media" href="/listings/{{ l.slug }}/">
      {% if l.images | length %}
        <img loading="lazy" src="{{ l.images[0] }}" alt="{{ l.title }}">
      {% else %}
        <span class="noimg">no photo</span>
      {% endif %}
      <span class="zbadge" style="background:{{ zm.color }}">{{ zm.label }}</span>
      <span class="score-badge" style="background:{{ scol }}" title="Target score {{ l.score }}/100">{{ l.score }}<small>/100</small></span>
      {% if l.imgCount %}<span class="imgcount">{{ l.imgCount }} photos</span>{% endif %}
    </a>
    <div class="card-body">
      <div class="card-top">
        <span class="price">฿{{ l.price }}<small>/mo</small></span>
        <span class="beds">{{ l.beds_baths or "—" }}</span>
      </div>
      <h2 class="card-area"><a href="/listings/{{ l.slug }}/">{{ l.area }}</a></h2>
      <p class="card-meta">{{ l.listed }}{% if l.move_in_date and l.move_in_date != "-" %} · {{ l.move_in_date }}{% endif %}</p>
      <div class="card-actions">
        <button type="button" class="act act-fav" data-act="fav" title="Favorite — sticky to top"><span class="star">☆</span> <span class="lbl">Favorite</span></button>
        <button type="button" class="act act-taken" data-act="taken" title="Mark as taken (hides it)">✓ <span class="lbl">Taken</span></button>
      </div>
    </div>
    <span class="taken-flag">TAKEN</span>
  </article>
  {% endfor %}
</div>

<p class="empty" id="empty" hidden>No listings match these filters.</p>

<script>
  const state = { zone: "all", price: 99999, beds: 0 };
  let curSort = "score", showTaken = false;
  const grid = document.getElementById("grid");
  const cards = [...document.querySelectorAll(".card")];

  // --- favorites + taken (persisted per-browser in localStorage) ---
  const FAV_KEY = "cmr_fav", TAKEN_KEY = "cmr_taken";
  const load = (k) => { try { return new Set(JSON.parse(localStorage.getItem(k) || "[]")); } catch (e) { return new Set(); } };
  const save = (k, s) => localStorage.setItem(k, JSON.stringify([...s]));
  let fav = load(FAV_KEY), taken = load(TAKEN_KEY);

  function markState(c) {
    const id = c.dataset.id;
    c.classList.toggle("is-fav", fav.has(id));
    c.classList.toggle("is-taken", taken.has(id));
    const favBtn = c.querySelector(".act-fav");
    if (favBtn) { favBtn.querySelector(".star").textContent = fav.has(id) ? "★" : "☆"; favBtn.classList.toggle("on", fav.has(id)); }
    const tBtn = c.querySelector(".act-taken");
    if (tBtn) { tBtn.querySelector(".lbl").textContent = taken.has(id) ? "Taken ✕" : "Taken"; tBtn.classList.toggle("on", taken.has(id)); }
  }

  // --- filters ---
  document.querySelectorAll(".chip[data-filter]").forEach(btn => {
    btn.addEventListener("click", () => {
      const f = btn.dataset.filter;
      btn.parentElement.querySelectorAll(".chip[data-filter]").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      state[f] = f === "zone" ? btn.dataset.val : Number(btn.dataset.val);
      refresh();
    });
  });

  function refresh() {
    let n = 0;
    cards.forEach(c => {
      const id = c.dataset.id;
      const okZone = state.zone === "all" || c.dataset.zone === state.zone;
      const okPrice = Number(c.dataset.price) <= state.price;
      const okBeds = Number(c.dataset.beds) >= state.beds;
      const isTaken = taken.has(id);
      const show = okZone && okPrice && okBeds && (!isTaken || showTaken);
      c.hidden = !show;
      if (show && !isTaken) n++;
      markState(c);
    });
    order();
    document.getElementById("visible-count").textContent = n;
    document.getElementById("empty").hidden = n > 0 || showTaken;
    document.getElementById("taken-count").textContent = taken.size;
    const favN = fav.size;
    document.getElementById("fav-summary").innerHTML = favN ? `<strong>★ ${favN}</strong> favourited · ` : "";
    document.getElementById("clear-marks").hidden = !(fav.size || taken.size);
  }

  // --- sort (favourites float to top, taken sink to bottom) ---
  const SORTS = { score:["score",-1], price:["price",1], "price-desc":["price",-1], recency:["recency",-1], movein:["movein",-1], location:["location",-1] };
  function order() {
    const [attr, dir] = SORTS[curSort] || SORTS.score;
    const rank = (c) => fav.has(c.dataset.id) ? 0 : (taken.has(c.dataset.id) ? 2 : 1);
    const ordered = [...cards].sort((a, b) => {
      const ra = rank(a), rb = rank(b);
      if (ra !== rb) return ra - rb;                       // fav → normal → taken
      const av = Number(a.dataset[attr]), bv = Number(b.dataset[attr]);
      if (av !== bv) return (av - bv) * dir;
      return Number(b.dataset.score) - Number(a.dataset.score);
    });
    ordered.forEach(c => grid.appendChild(c));
  }
  document.getElementById("sort").addEventListener("change", e => { curSort = e.target.value; order(); });

  // --- mark buttons (event delegation) ---
  grid.addEventListener("click", (e) => {
    const b = e.target.closest("[data-act]");
    if (!b) return;
    e.preventDefault();
    const id = b.closest(".card").dataset.id;
    if (b.dataset.act === "fav") {
      fav.has(id) ? fav.delete(id) : (fav.add(id), taken.delete(id));
    } else {
      taken.has(id) ? taken.delete(id) : (taken.add(id), fav.delete(id));
    }
    save(FAV_KEY, fav); save(TAKEN_KEY, taken);
    refresh();
  });

  document.getElementById("toggle-taken").addEventListener("click", (e) => {
    showTaken = !showTaken;
    e.target.classList.toggle("active", showTaken);
    refresh();
  });
  document.getElementById("clear-marks").addEventListener("click", () => {
    if (!confirm("Clear all your favourites and taken marks?")) return;
    fav.clear(); taken.clear(); save(FAV_KEY, fav); save(TAKEN_KEY, taken);
    showTaken = false; document.getElementById("toggle-taken").classList.remove("active");
    refresh();
  });

  refresh();
</script>
